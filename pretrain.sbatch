#!/bin/bash
#SBATCH --account=csci_ga_2572-2026sp
#SBATCH --partition=c24m170-a100-2
#SBATCH --job-name=jepa-pretrain
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --gres=gpu:2
#SBATCH --time=24:00:00
#SBATCH --requeue
#SBATCH --output=pretrain_%j.out
#SBATCH --error=pretrain_%j.err
#SBATCH --signal=B:USR1@120

set -euo pipefail

REPO=/scratch/$USER/physical-representation-learning
OVERLAY=$REPO/overlay-15GB-500K.ext3
IMAGE=/share/apps/images/cuda13.0.1-cudnn9.13.0-ubuntu-24.04.3.sif
CKPT_DIR=/scratch/$USER/physics_jepa/ckpts
CONFIG=configs/train_activematter_small.yaml

mkdir -p "$CKPT_DIR"

trap 'echo "[$(date)] SIGUSR1 received — requeuing"; exit 0' USR1

echo "[$(date)] Job $SLURM_JOB_ID on $(hostname)"
nvidia-smi

singularity exec --nv \
  --overlay "$OVERLAY:ro" \
  --bind /scratch/$USER:/scratch/$USER \
  "$IMAGE" bash -c "
    source /share/apps/anaconda3/2024.02/etc/profile.d/conda.sh
    conda activate jepa
    cd $REPO
    export THE_WELL_DATA_DIR=/scratch/$USER/physics_jepa/data
    export WANDB_API_KEY=\${WANDB_API_KEY:-}
    torchrun --standalone --nproc_per_node=2 -m physics_jepa.train \
      --config $CONFIG \
      --checkpoint_dir $CKPT_DIR \
      --resume_if_exists
  "

echo "[$(date)] Done"
