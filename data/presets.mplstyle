font.family: sans-serif
font.size: 10
axes.titlesize: 11
axes.labelsize: 10
axes.grid: True
grid.alpha: 0.25
grid.linestyle: --
legend.fontsize: 9
legend.frameon: True
legend.framealpha: 0.85
xtick.labelsize: 9
ytick.labelsize: 9
figure.dpi: 110
savefig.dpi: 200
savefig.bbox: tight
lines.linewidth: 1.6
lines.markersize: 5
